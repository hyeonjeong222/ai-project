{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/internal/ingestion/run",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "app/api/internal/ingestion/run/route.ts": {
      "maxDuration": 300
    },
    "app/v1/chat/threads/[threadId]/messages/route.ts": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/v1/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
