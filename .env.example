# Browser-safe Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Server-only secrets (never prefix these with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_RESPONSE_MODEL=gpt-5.6-luna
CRON_SECRET=replace-with-at-least-32-random-characters

# RAG/worker operational settings
RAG_MAX_FILE_BYTES=26214400
RAG_WORKER_ID=local-worker
RAG_WORKER_BATCH_SIZE=1
